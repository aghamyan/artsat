# Supabase - get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend - get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin email for order alerts
ADMIN_EMAIL=admin@artsat.com

# From email (must be verified domain in Resend)
FROM_EMAIL=orders@artsat.com
FROM_NAME=Artsat Clothing

# Stripe (Phase 4 - scaffold only, leave as placeholder for now)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# App URL (used for email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
